{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "FTE_MODE": "production",
    "PYTHON_VERSION": "3.11"
  },
  "regions": ["iad1"],
  "outputDirectory": "api"
}
