# =============================================================================
# Customer Success FTE — Environment Configuration
# =============================================================================
# Copy this file to .env and update with your values
# DO NOT commit .env to version control

# =============================================================================
# MODE: "local" (dev, no Kafka) or "production" (full infrastructure)
# =============================================================================
FTE_MODE=

# =============================================================================
# SERVER
# =============================================================================
FTE_HOST=
FTE_PORT=
FTE_WORKERS=
FTE_DEBUG=

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_POOL_MIN=
DB_POOL_MAX=

# =============================================================================
# KAFKA (production mode only)
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC_INCOMING=
KAFKA_TOPIC_OUTGOING=
KAFKA_TOPIC_DLQ=
KAFKA_TOPIC_METRICS=

# =============================================================================
# SECURITY
# =============================================================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
JWT_SECRET=
RATE_LIMIT_REQUESTS=
RATE_LIMIT_WINDOW=
# =============================================================================
# CORS — Comma-separated list of allowed origins
# =============================================================================
ALLOWED_ORIGINS=

# =============================================================================
# GMAIL (optional — leave empty to disable)
# =============================================================================
GMAIL_CREDENTIALS_PATH=
GMAIL_PROJECT_ID=
GMAIL_TOPIC_NAME=

# =============================================================================
# WHATSAPP / TWILIO (optional — leave empty to disable)
# =============================================================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# =============================================================================
# OPENAI (optional — leave empty to skip AI agent)
# =============================================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
AGENT_MODEL=

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
# LOG_FORMAT=text  (development) or json (production)
LOG_FORMAT=text
